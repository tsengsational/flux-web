{
  "name": "flux-theatre-migration",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the Flux Theatre Ensemble headless website migration",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @flux-theatre/web dev",
    "dev:cms": "pnpm --filter @flux-theatre/cms dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @flux-theatre/web build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
