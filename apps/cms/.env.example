####################################
# Directus — General Configuration
####################################
HOST="0.0.0.0"
PORT=8055
PUBLIC_URL="https://your-directus-instance.railway.app"
LOG_LEVEL="info"

####################################
# Directus — Secret & Auth
####################################
SECRET="replace-with-a-random-256-bit-secret"
ADMIN_EMAIL="admin@fluxtheatre.org"
ADMIN_PASSWORD="change-me-immediately"

####################################
# Database — Supabase PostgreSQL
####################################
DB_CLIENT="pg"
DB_HOST="db.your-project-ref.supabase.co"
DB_PORT=5432
DB_DATABASE="postgres"
DB_USER="postgres"
DB_PASSWORD="your-supabase-db-password"
DB_SSL="true"

####################################
# Storage — Supabase S3 (for media)
####################################
STORAGE_LOCATIONS="supabase"
STORAGE_SUPABASE_DRIVER="s3"
STORAGE_SUPABASE_KEY="your-supabase-s3-access-key"
STORAGE_SUPABASE_SECRET="your-supabase-s3-secret-key"
STORAGE_SUPABASE_BUCKET="flux-theatre-media"
STORAGE_SUPABASE_REGION="us-east-1"
STORAGE_SUPABASE_ENDPOINT="https://your-project-ref.supabase.co/storage/v1/s3"
STORAGE_SUPABASE_FORCE_PATH_STYLE="true"

####################################
# CORS — Frontend Origin
####################################
CORS_ENABLED="true"
CORS_ORIGIN="https://fluxtheatre.org,http://localhost:3000"

####################################
# Telemetry
####################################
TELEMETRY="false"
